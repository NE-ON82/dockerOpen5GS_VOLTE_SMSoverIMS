#!/usr/bin/env bash
# volte — VoLTE test ağı yönetim CLI'ı.
#
# Kullanım:
#   ./volte start                  (EPC + eNB başlatır)
#   ./volte stop [--all]           (Sadece eNB durdurur, --all tüm yığını durdurur)
#   ./volte restart                (eNB'yi yeniden başlatır)
#   ./volte status                 (Çalışan servisleri gösterir)
#   ./volte corestatus             (IMS ve Çekirdek bileşenlerinin detaylı durumu)
#   ./volte enable-boot            (Çekirdeği kalıcı yapar)
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/ayarlar.sh"
source "${SCRIPT_DIR}/lib/servis.sh"

kullanim() {
  cat <<EOF
volte — VoLTE Yönetim CLI

Kullanım:
  ./volte start                  (EPC + eNB başlatır)
  ./volte stop [--all]           (Sadece eNB durdurur, --all tüm yığını durdurur)
  ./volte restart                (eNB'yi yeniden başlatır)
  ./volte status                 (Çalışan servisleri gösterir)
  ./volte corestatus             (IMS ve Çekirdek detaylı durumu)
  ./volte enable-boot            (Çekirdeği kalıcı yapar)
  
Not: Abone işlemleri için './abone_ekle.sh' scriptini kullanın.
PLMN işlemleri için './plmn.sh' scriptini kullanın.
EOF
}

main() {
  [ $# -eq 0 ] && { kullanim; exit 0; }
  local sub="$1"; shift || true
  case "$sub" in
    start)
      servis_start;;
    stop)
      servis_stop "${1:-}";;
    restart)
      servis_restart;;
    status)
      servis_status;;
    corestatus)
      servis_corestatus;;
    enable-boot)
      servis_enable_boot;;
    disable-boot)
      servis_disable_boot;;
    -h|--help|help)
      kullanim;;
    *)
      c_err "Bilinmeyen komut: $sub"; kullanim; exit 1;;
  esac
}

main "$@"
